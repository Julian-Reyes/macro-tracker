# Database (SQLite - stored locally)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-to-a-random-string"

# AI Providers (add the ones you want to use)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ollama (local, no key needed)
OLLAMA_URL=http://localhost:11434

# Default AI provider: anthropic | gemini | openai | ollama
AI_PROVIDER=gemini

# USDA FoodData Central (free key from https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=

# Image storage directory (local disk for now)
UPLOAD_DIR=./uploads

# Server
PORT=3001
